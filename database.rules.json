{
  "rules": {
    ".read": false,
    ".write": false,
    
    "organizations": {
      "$orgId": {
        ".read": "auth != null",
        ".write": "auth != null",
        
        "connections": {
          "$connId": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        },
        
        "transactions": {
          "$txId": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        },
        
        "nexus": {
          "$stateCode": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        }
      }
    },
    
    "users": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null && auth.uid == $userId"
      }
    },
    
    "subscriptions": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null && auth.uid == $userId"
      }
    }
  }
}
